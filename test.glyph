int count = 0   // global variable – outside all functions

func init() {
    int x = 10
    print("Initializing...")
    print(x)
}

func setup() {
    print("Setting up...")
}

func start() {
    print("Starting...")
}

func loop() {
    count = count + 1
    print("Looping...")
    if (count > 5) {
        stop
    }
}

func shutdown() {
    print("Shutting down... (never reached)")
}
